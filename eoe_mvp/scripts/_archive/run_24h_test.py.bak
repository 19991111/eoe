#!/usr/bin/env python3
"""
EOE 24小时演化测试 - 话痨版 (已修复)
增强监控: 实时战报、DeepSeek神谕、进化Diagnostic
修复: 使用完整NEAT进化 + 正确谢计算
"""

import os
import sys
import json
import time
import signal
import requests
import random
import numpy as np
from datetime import datetime
from dataclasses import dataclass
from typing import List, Dict

# 设置GPU 3
os.environ['CUDA_VISIBLE_DEVICES'] = '3'

PROJECT_ROOT = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
sys.path.insert(0, PROJECT_ROOT)

from core.eoe import Environment, Agent
from core.eoe.node import Node, NodeType

# FeishuWebhook
FEISHU_WEBHOOK = "https://open.feishu.cn/open-apis/bot/v2/hook/a581dcb1-8994-41e9-aa88-efcb9c0bf9b1"
LOG_FILE = os.path.join(PROJECT_ROOT, "demiurge_decisions.log")

# 颜色输出
class Colors:
    HEADER = '\033[95m'
    BLUE = '\033[94m'
    GREEN = '\033[92m'
    WARNING = '\033[93m'
    FAIL = '\033[91m'
    ENDC = '\033[0m'
    BOLD = '\033[1m'

def send_feishu(message: str):
    try:
        payload = {"msg_type": "text", "content": {"text": f"[EOE 24h测试] {message}"}}
        requests.post(FEISHU_WEBHOOK, json=payload, timeout=10)
    except:
        pass

def print_stats(generation: int, agents: List, env, speed: float, elapsed: float):
    """打印实时战报"""
    if not agents:
        print(f"{Colors.FAIL} 种群灭绝!{Colors.ENDC}")
        return
    
    # alive数
    alive = sum(1 for a in agents if a.is_alive)
    
    # 适应度
    max_fitness = max((a.fitness for a in agents), default=0)
    avg_fitness = np.mean([a.fitness for a in agents]) if agents else 0
    
    # 行为统计
    total_carried = sum(getattr(a, 'food_carried', 0) for a in agents)
    total_stored = sum(getattr(a, 'food_stored', 0) for a in agents)
    total_eaten = sum(getattr(a, 'food_eaten', 0) for a in agents)
    
    # 能量统计
    energy_spent = np.mean([getattr(a, 'energy_spent', 0) for a in agents])
    
    # 脑复杂度
    brain_nodes = []
    brain_edges = []
    for a in agents:
        if hasattr(a, 'genome') and a.genome:
            info = a.genome.get_info()
            brain_nodes.append(info.get('total_nodes', 0))
            brain_edges.append(info.get('enabled_edges', 0))
    avg_nodes = np.mean(brain_nodes) if brain_nodes else 0
    avg_edges = np.mean(brain_edges) if brain_edges else 0
    
    # season
    season = "summer" if env.current_season == "summer" else "winter"
    winter_temp = getattr(env, 'winter_temperature', -10)
    adhesion = getattr(env, 'adhesion_range', 3.0)
    
    print(f"{Colors.HEADER}{'='*70}{Colors.ENDC}")
    print(f"{Colors.BOLD}⏱️ Gen {generation}  | {elapsed/3600:.2f}h | {speed:.1f}/秒{Colors.ENDC}")
    print(f"{Colors.HEADER}{'='*70}{Colors.ENDC}")
    print(f"   种群: {alive} alive | Max fitness: {max_fitness:.1f} | avg: {avg_fitness:.1f}")
    print(f"   eaten: {total_eaten} |  carried: {total_carried} |  stored: {total_stored}")
    print(f"   avg能耗: {energy_spent:.2f} |  脑复杂度: {avg_nodes:.1f}nodes/{avg_edges:.1f}边")
    print(f"   season: {season} | winter temp: {winter_temp}°C | adhesion: {adhesion}")
    print()

def print_llm_oracle(generation: int, response: Dict):
    """打印DeepSeek神谕"""
    print(f"{Colors.BLUE}{''*20}{Colors.ENDC}")
    print(f"{Colors.BLUE} DeepSeek Oracle @ Gen {generation}{Colors.ENDC}")
    print(f"{Colors.BLUE}{''*20}{Colors.ENDC}")
    
    # Reflection
    reflection = response.get('reflection', '')
    if reflection:
        print(f"{Colors.BLUE} Reflection:{Colors.ENDC}")
        print(f"   {reflection}")
    
    # Evolution Story
    story = response.get('evolution_story', '')
    if story:
        print(f"\n{Colors.BLUE} Evolution Story:{Colors.ENDC}")
        print(f"   {story}")
    
    # Parameter Adjustments
    pc = response.get('physics_config', {})
    if pc:
        print(f"\n{Colors.WARNING} Parameter Adjustments:{Colors.ENDC}")
        for k in ['metabolic_alpha', 'metabolic_beta', 'sensor_range', 'food_energy', 
                  'season_length', 'winter_metabolic_multiplier', 'fatigue_build_rate']:
            if k in pc:
                print(f"   {k}: {pc[k]}")
        print(f"\n   信心指数: {response.get('confidence', 'N/A')}")

def simple_genome_factory() -> 'OperatorGenome':
    """创建简单初始基因组"""
    from core.eoe.genome import OperatorGenome
    genome = OperatorGenome()
    
    # 输入nodes
    sensor = Node(node_id=0, node_type=NodeType.SENSOR)
    genome.add_node(sensor)
    
    # 输出nodes
    actuator = Node(node_id=1, node_type=NodeType.ACTUATOR)
    genome.add_node(actuator)
    
    # 初始连接
    genome.add_edge(0, 1, weight=1.0)
    
    return genome

if __name__ == "__main__":
    np.random.seed(42)
    random.seed(42)
    
    # Loading physics config
    config_path = os.path.join(PROJECT_ROOT, "physics_config.json")
    try:
        with open(config_path, 'r') as f:
            physics_config = json.load(f)
        print(f"{Colors.BLUE} Loading physics config: metabolic_alpha={physics_config.get('metabolic_alpha', 'N/A')}{Colors.ENDC}")
    except Exception as e:
        print(f"{Colors.WARNING} 配置加载failed: {e}, using default{Colors.ENDC}")
        physics_config = {}
    
    # 初始化环境 (扩大资源+种群)
    env = Environment(
        width=100, height=100, n_food=20, 
        seasonal_cycle=True, season_length=physics_config.get('season_length', 80),
        metabolic_alpha=physics_config.get('metabolic_alpha', 0.01),  # 降低谢
        metabolic_beta=physics_config.get('metabolic_beta', 0.01),
        winter_metabolic_multiplier=physics_config.get('winter_metabolic_multiplier', 1.5),
        food_energy=physics_config.get('food_energy', 40)
    )
    env.sensor_range = physics_config.get('sensor_range', 40.0)
    env.food_energy = physics_config.get('food_energy', 40)
    env.enable_thermal_sanctuary(summer_temp=25, winter_temp=-10, food_heat=15)
    env.enable_fatigue_system()
    env.enable_morphological_computation(adhesion_range=3.0, carry_speed_penalty=0.7)
    
    print(f"{Colors.GREEN}[Thermal Sanctuary] Enabled: summer=25°C, winter=-10°C, food_heat=15{Colors.ENDC}")
    print(f"{Colors.GREEN}[Morphological] Enabled: adhesion=3.0, carry_penalty=0.7{Colors.ENDC}")
    
    # 初始化种群 (使用NEAT基因组)
    from core.eoe.genome import OperatorGenome
    agents = []
    for i in range(50):
        a = Agent(
            agent_id=i,
            x=50 + np.random.random() * 10,
            y=50 + np.random.random() * 10,
            theta=np.random.random() * 6.28
        )
        a.genome = simple_genome_factory()
        env.add_agent(a)  # 关键: 添加到环境!
        agents.append(a)
    
    print(f"{Colors.HEADER}{'='*70}")
    print("🧪 EOE 24小时演化测试 - 话痨版 (已修复)")
    print(f"时间: {datetime.now()}")
    print(f"GPU: 3")
    print(f"{'='*70}{Colors.ENDC}\n")
    
    send_feishu("24小时话痨版test started!(已修复能量谢)")
    
    start_time = time.time()
    generation = 0
    last_llm_call = 0
    history = []
    
    # LLM初始化
    from scripts.llm_demiurge_loop import LLMDemiurge, generate_epoch_report, BASE_CONSTITUTION
    llm = None
    
    try:
        llm = LLMDemiurge()
        print(f"{Colors.GREEN}✅ DeepSeek LLM 已连接{Colors.ENDC}\n")
    except Exception as e:
        print(f"{Colors.WARNING} LLM初始化failed: {e}{Colors.ENDC}")
        print(f"   将使用无LLM模式继续测试\n")
    
    print_stats(generation, agents, env, 0, 0)
    
    try:
        while True:
            if time.time() - start_time >= 24 * 3600:
                break
            
            # 使用环境的完整step函数 (包含正确谢!)
            env.step()
            
            # 收集活着的agent
            alive_agents = [a for a in agents if a.is_alive]
            
            # 补充新Agent (使用NEAT复制)
            target_pop = 50
            if len(alive_agents) < target_pop:
                # 精英复制: 从最优者复制
                alive_agents.sort(key=lambda a: a.fitness, reverse=True)
                best = alive_agents[0] if alive_agents else None
                
                for i in range(target_pop - len(alive_agents)):
                    new_id = generation * 100 + i
                    a = Agent(
                        agent_id=new_id,
                        x=50 + np.random.random() * 10,
                        y=50 + np.random.random() * 10,
                        theta=np.random.random() * 6.28
                    )
                    
                    if best and hasattr(best, 'genome') and best.genome:
                        # 复制+突变
                        a.genome = best.genome.copy()
                        a.genome.mutate_add_node()
                        a.genome.mutate_add_edge()
                        a.genome.mutate_weight(sigma=0.1, probability=0.3)
                    else:
                        a.genome = simple_genome_factory()
                    
                    env.add_agent(a)  # 关键: 添加到环境!
                    agents.append(a)
                    alive_agents.append(a)
            
            agents = alive_agents
            generation += 1
            elapsed = time.time() - start_time
            speed = generation / elapsed if elapsed > 0 else 0
            
            # 记录历史
            if generation % 100 == 0:
                history.append({
                    'gen': generation,
                    'stored': sum(getattr(a, 'food_stored', 0) for a in agents),
                    'eaten': sum(getattr(a, 'food_eaten', 0) for a in agents),
                    'fitness': np.mean([a.fitness for a in agents]) if agents else 0
                })
            
            # 每1000打印详细统计
            if generation % 1000 == 0:
                print_stats(generation, agents, env, speed, elapsed)
            
            # 每10000调用DeepSeek
            if llm and generation - last_llm_call >= 10000:
                print(f"\n{Colors.BLUE} Calling DeepSeek...{Colors.ENDC}")
                
                try:
                    epoch_data = {'generation': generation, 'agents': agents, 'env': env}
                    report = generate_epoch_report(epoch_data)
                    
                    response = llm._send_to_deepseek(BASE_CONSTITUTION[:600], report[:2000])
                    validated = llm._validate_response(response)
                    
                    if validated:
                        print_llm_oracle(generation, validated)
                        llm._save_config(llm.current_config)
                        
                        # 写入日志
                        with open(LOG_FILE, 'a', encoding='utf-8') as f:
                            f.write(f"\n{'='*60}\n")
                            f.write(f"纪元: {generation}\n")
                            f.write(f"时间: {datetime.now().isoformat()}\n")
                            f.write(f"Reflection: {validated.get('reflection', '')}\n")
                            f.write(f"Evolution Story: {validated.get('evolution_story', '')}\n")
                            f.write(f"Physics Config: {json.dumps(validated.get('physics_config', {}))}\n")
                        
                        # 保存检查点
                        if generation % 10000 == 0:
                            ckpt = os.path.join(PROJECT_ROOT, "champions", f"gen_{generation}.json")
                            os.makedirs(os.path.dirname(ckpt), exist_ok=True)
                            # 保存最佳agent
                            if agents:
                                best = max(agents, key=lambda a: a.fitness)
                                # 简单保存
                                with open(ckpt, 'w') as f:
                                    json.dump({
                                        'gen': generation,
                                        'fitness': best.fitness,
                                        'food_stored': getattr(best, 'food_stored', 0)
                                    }, f)
                            print(f"{Colors.GREEN} Checkpoint saved: Gen {generation}{Colors.ENDC}")
                    
                        last_llm_call = generation
                    else:
                        print(f"{Colors.WARNING} LLM response validation failed{Colors.ENDC}")
                except Exception as e:
                    print(f"{Colors.WARNING} LLM call failed: {e}{Colors.ENDC}")
            
            # 每5000Diagnostic
            if generation % 5000 == 0 and generation > 0:
                avg_energy = np.mean([a.energy_spent for a in agents]) if agents else 0
                brain_complexity = []
                for a in agents:
                    if hasattr(a, 'genome') and a.genome:
                        info = a.genome.get_info()
                        brain_complexity.append(info.get('total_nodes', 0))
                avg_brain = np.mean(brain_complexity) if brain_complexity else 0
                
                print(f"{Colors.WARNING} Diagnostic @ Gen {generation}:")
                print(f"   Avg energy: : {avg_energy:.2f}")
                print(f"   Avg brain: : {avg_brain:.1f} nodes")
                if avg_energy < 0.1:
                    print(f"   WARNING: Energy consumption too low!")